#!/usr/bin/env python3
import json, sys

try:
    d = json.load(open(f'{sys.argv[1] if len(sys.argv) > 1 else "/home/necro/.config/noctalia/colors.json"}'))
except FileNotFoundError:
    print("No colors.json found. Is Noctalia running?")
    sys.exit(1)

groups = {
    'Source': ['source_color'],
    'Primary': ['primary', 'on_primary', 'primary_container', 'on_primary_container', 'primary_fixed', 'primary_fixed_dim'],
    'Secondary': ['secondary', 'on_secondary', 'secondary_container', 'on_secondary_container', 'secondary_fixed', 'secondary_fixed_dim'],
    'Tertiary': ['tertiary', 'on_tertiary', 'tertiary_container', 'on_tertiary_container', 'tertiary_fixed', 'tertiary_fixed_dim'],
    'Error': ['error', 'on_error', 'error_container', 'on_error_container'],
    'Surface': ['surface', 'on_surface', 'surface_variant', 'on_surface_variant', 'surface_dim', 'surface_bright', 'surface_container', 'surface_container_high'],
    'Outline/Shadow': ['outline', 'outline_variant', 'shadow'],
    'Inverse': ['inverse_surface', 'inverse_on_surface', 'inverse_primary'],
    'Background': ['background', 'on_background'],
}

seen = set()
for group, roles in groups.items():
    print(f'\n  \033[1m{group}\033[0m')
    print(f'  {"─" * (len(group)+2)}')
    for r in roles:
        seen.add(r)
        v = d.get(r, '')
        if isinstance(v, str) and len(v) == 7 and v[0] == '#':
            r2, g2, b2 = int(v[1:3],16), int(v[3:5],16), int(v[5:7],16)
            lum = 0.299*r2 + 0.587*g2 + 0.114*b2
            fg = '38;5;0' if lum > 140 else '38;5;255'
            print(f'  \033[{fg}m{r:30s} \033[48;2;{r2};{g2};{b2}m  {v}  \033[0m')
        else:
            print(f'  {r:30s} (unavailable)')

remaining = [k for k in d if k not in seen and isinstance(d[k], str) and d[k].startswith('#') and k != 'wallpaper_scheme']
if remaining:
    print(f'\n  \033[1mOther\033[0m')
    print(f'  {"─────"}')
    for r in remaining:
        v = d.get(r, '')
        if isinstance(v, str) and len(v) == 7:
            r2, g2, b2 = int(v[1:3],16), int(v[3:5],16), int(v[5:7],16)
            lum = 0.299*r2 + 0.587*g2 + 0.114*b2
            fg = '38;5;0' if lum > 140 else '38;5;255'
            print(f'  \033[{fg}m{r:30s} \033[48;2;{r2};{g2};{b2}m  {v}  \033[0m')

print()

// Configuracion para bordes rectangulares
window-rule {
  geometry-corner-radius 0
  clip-to-geometry true 
}
window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}
// Aplicaciones que se abriran maximizadas 
window-rule {
    match app-id="vlc"
    match app-id="firefox"
    open-maximized true 
}
// Aplicaciones que se abriran en el segundo monitor por defecto 
window-rule {
    match app-id="discord" 
    match app-id=r#"(?i)spotify"#
    open-on-output "HDMI-A-1" 
    open-maximized true
}
//Configuracion de xdg-apps
window-rule {
  match app-id="Xdg-desktop-portal-gtk"
  focus-ring {
    off
  } 
}
// Noctalia backdrop: blurred/tinted wallpaper in overview
layer-rule {
    match namespace="^noctalia-backdrop"
    place-within-backdrop true
}
// Noctalia settings window
window-rule {
    match app-id="dev.noctalia.Noctalia"
    open-floating true
    default-column-width { fixed 1080; }
    default-window-height { fixed 920; }
}
debug {
    honor-xdg-activation-with-invalid-serial
}
// Blur solo para tiling
window-rule {
    match is-floating=false
    background-effect {
        blur true
    }
}
// Tiled unfocused: 80% opacidad (20% transparente)
window-rule {
    match is-floating=false is-focused=false
    opacity 0.80
}
// Tiled focused: 90% opacidad (10% transparente)
window-rule {
    match is-floating=false is-focused=true
    opacity 0.95
}
// Floating sin foco: 98% transparente, sin blur
window-rule {
    match is-floating=true is-focused=false
    opacity 0.02
}
// Blur para superficies Noctalia
layer-rule {
    match namespace="^noctalia-(bar-[^\"]+|notification|dock|panel|attached-panel|osd)$"
    background-effect {
        blur true
        xray false
    }
}
blur {
    passes 2
    offset 3.0
    noise 0.03
    saturation 1.0
}


